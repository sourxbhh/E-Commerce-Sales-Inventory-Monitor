# ==================== Kafka ====================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ORDERS_TOPIC=orders
KAFKA_INVENTORY_TOPIC=inventory-updates

# ==================== MySQL ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=ecom_user
MYSQL_PASSWORD=ecom_pass
MYSQL_DATABASE=ecommerce_rt
MYSQL_ROOT_PASSWORD=root_pass

# ==================== FakeStoreAPI (live catalog source) ====================
FAKESTORE_BASE_URL=https://fakestoreapi.com
CATALOG_SYNC_INTERVAL=300

# ==================== FastAPI live-edge service ====================
API_HOST=0.0.0.0
API_PORT=8000
ORDER_RATE_MIN_SECONDS=2
ORDER_RATE_MAX_SECONDS=5

# ==================== Burst / demo injection ====================
BURST_ENABLED=true
BURST_EVERY_SECONDS=180
BURST_SIZE=30
BURST_DURATION_SECONDS=10

# ==================== Anomaly detection ====================
ANOMALY_CHECK_INTERVAL=60
ANOMALY_WINDOW_MINUTES=30
ANOMALY_METHOD=isolation_forest

# ==================== KPI evaluator ====================
KPI_CHECK_INTERVAL=60
