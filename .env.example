# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ORDERS_TOPIC=orders
KAFKA_INVENTORY_TOPIC=inventory-updates

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=ecom_user
MYSQL_PASSWORD=ecom_pass
MYSQL_DATABASE=ecommerce_rt
MYSQL_ROOT_PASSWORD=root_pass

# Generator
ORDER_INTERVAL_MIN=2
ORDER_INTERVAL_MAX=5
BURST_ENABLED=true
BURST_EVERY_SECONDS=180
BURST_SIZE=30
BURST_DURATION_SECONDS=10

# Anomaly
ANOMALY_CHECK_INTERVAL=60
ANOMALY_WINDOW_MINUTES=30
ANOMALY_METHOD=isolation_forest

# KPI
KPI_CHECK_INTERVAL=60
